# Copy to `.env` (gitignored) and set real values.
#
#   cp .env.example .env
#   # then edit the tokens below

# Namespaces this demo's containers/network/volumes. Keeps it isolated.
COMPOSE_PROJECT_NAME=lwcp-demo

# Loopback TLS port the proxy publishes. NOT 8000.
PROXY_TLS_PORT=8443

# Chroma's single static service token. The proxy holds this and injects it
# upstream on every request; clients never see it.
#   generate:  openssl rand -hex 32
CHROMA_TOKEN=demo-chroma-service-token-CHANGE-ME

# The writer (admission) token clients present to gain write access. This MUST
# match the pattern in sample/nginx/writer_tokens.map. smoke-test.sh reads it.
#   generate:  openssl rand -hex 32
WRITER_TOKEN=demo-writer-token-CHANGE-ME
